// Common URL aliases used across PRO Library FSH sources.

Alias: $LOINC = http://loinc.org
Alias: $SNOMED = http://snomed.info/sct

Alias: $sdc-questionnaire = http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire
Alias: $ordinalValue = http://hl7.org/fhir/StructureDefinition/ordinalValue
Alias: $translation = http://hl7.org/fhir/StructureDefinition/translation
Alias: $variable = http://hl7.org/fhir/StructureDefinition/variable
Alias: $sdc-calculatedExpression = http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression
Alias: $sdc-initialExpression = http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression
Alias: $observation-extract = http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract
Alias: $sdc-observation-extract-category = http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observation-extract-category
Alias: $cqf-library = http://hl7.org/fhir/StructureDefinition/cqf-library
Alias: $questionnaire-unit = http://hl7.org/fhir/StructureDefinition/questionnaire-unit
Alias: $observation-category = http://terminology.hl7.org/CodeSystem/observation-category
Alias: $ucum = http://unitsofmeasure.org

Alias: $mii-pro-namespace = https://www.medizininformatik-initiative.de/fhir/ext/modul-pro
Alias: $mii-pro-q-phq-9 = https://www.medizininformatik-initiative.de/fhir/ext/modul-pro/Questionnaire/mii-qst-pro-phq-9

Alias: $provenance-participant = http://terminology.hl7.org/CodeSystem/provenance-participant-type
Alias: $library-type = http://terminology.hl7.org/CodeSystem/library-type
Alias: $testscript-operation-code = http://terminology.hl7.org/CodeSystem/testscript-operation-codes

// CQF Knowledge Capability extensions (used to claim CRMI Shareable / Computable / Publishable / Executable tiers)
Alias: $cqf-knowledgeCapability = http://hl7.org/fhir/StructureDefinition/cqf-knowledgeCapability
Alias: $cqf-knowledgeRepresentationLevel = http://hl7.org/fhir/StructureDefinition/cqf-knowledgeRepresentationLevel
