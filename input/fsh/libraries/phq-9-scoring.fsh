// PHQ-9 Scoring Library
//
// Authoritative computable scoring for PHQ-9:
//   - PHQ9TotalScore       (raw sum 0..27)
//   - PHQ9Severity         (band per Kroenke 2001 cut-points)
//   - PROMISDepressionTScore  (raw → T-Score via PROsetta Stone cross-walk)
//
// CQL source: input/cql/PHQ9.cql
// ELM JSON: pre-compiled via cql-to-elm v4.7.0 with signatures=Overloads
// Bound to Questionnaire/phq-9 via the cqf-library extension.

Instance: phq-9-scoring
InstanceOf: Library
Usage: #definition
Description: "CQL scoring library for PHQ-9: total score, severity band, PROMIS depression T-score."

* id = "phq-9-scoring"
* url = "https://fhir.bih-charite.de/pro-library/Library/phq-9-scoring"
* version = "0.1.1"
// Library.name MUST match the CQL library declaration identifier so that
// HAPI CR's FhirLibrarySourceProvider can resolve the source.
* name = "phq-9-scoring"
* title = "PHQ-9 Scoring Library"
* status = #active
* experimental = true
* date = "2026-05-16"
* publisher = "BIH-CEI (provisional steward)"
* type = $library-type#logic-library "Logic Library"

* relatedArtifact[+].type = #depends-on
* relatedArtifact[=].resource = "https://fhir.bih-charite.de/pro-library/Questionnaire/phq-9|0.1.1"
* relatedArtifact[=].display = "PHQ-9 Questionnaire scored by this Library"

* relatedArtifact[+].type = #citation
* relatedArtifact[=].display = "Kroenke K, Spitzer RL, Williams JBW. The PHQ-9. J Gen Intern Med 2001;16(9):606-13."
* relatedArtifact[=].url = "https://doi.org/10.1046/j.1525-1497.2001.016009606.x"

* relatedArtifact[+].type = #citation
* relatedArtifact[=].display = "Choi SW, Schalet B, Cook KF, Cella D. Establishing a common metric for depressive symptoms: linking the BDI-II, CES-D, and PHQ-9 to PROMIS Depression. Psychol Assess 2014;26(2):513-27."
* relatedArtifact[=].url = "https://doi.org/10.1037/a0035768"

* copyright = """FHIR encoding © 2026 BIH-CEI. Released under CC-BY-4.0.
PHQ-9 © Kroenke, Spitzer & Williams (2001), freely available with attribution.
PROMIS Depression T-score mapping per PROsetta Stone (Choi et al. 2014)."""

* extension[+].url = $cqf-knowledgeCapability
* extension[=].valueCode = #shareable
* extension[+].url = $cqf-knowledgeCapability
* extension[=].valueCode = #computable
* extension[+].url = $cqf-knowledgeCapability
* extension[=].valueCode = #executable
* extension[+].url = $cqf-knowledgeRepresentationLevel
* extension[=].valueCode = #executable

// CQL source — see input/cql/PHQ9.cql for the editable form.
* content[+].contentType = #text/cql
* content[=].title = "PHQ9.cql"
* content[=].data = ""

// ELM JSON pre-compiled via cql-to-elm v4.7.0 with signatures=Overloads.
// Shipping ELM means runtime engines don't need to re-translate.
* content[+].contentType = #application/elm+json
* content[=].title = "PHQ9.json"
* content[=].data = ""

