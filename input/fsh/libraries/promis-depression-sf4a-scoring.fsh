// PROMIS Depression SF-4a Scoring Library
//
// 4-item short form, 5-pt Likert (1..5).
//   - PROMISDepressionSF4aRawScore    (sum 4..20)
//   - PROMISDepressionSF4aTScore      (T-Score via PROMIS scoring manual lookup)
//
// CQL source: input/cql/PROMISDepressionSF4a.cql
// ELM JSON: pre-compiled via cql-to-elm v4.7.0 with signatures=Overloads
// SDC Flow A (context Patient + retrieve) — same pattern as phq-9-scoring.

Instance: promis-depression-sf4a-scoring
InstanceOf: Library
Usage: #definition
Description: "CQL scoring library for PROMIS Depression SF-4a (raw + T-Score)."

* id = "promis-depression-sf4a-scoring"
* url = "https://fhir.bih-charite.de/pro-library/Library/promis-depression-sf4a-scoring"
* version = "0.1.3"
* name = "promis-depression-sf4a-scoring"
* title = "PROMIS Depression SF-4a Scoring Library"
* status = #active
* experimental = true
* date = "2026-05-17"
* publisher = "BIH-CEI (provisional steward)"
* type = $library-type#logic-library "Logic Library"

* relatedArtifact[+].type = #depends-on
* relatedArtifact[=].resource = "https://fhir.bih-charite.de/pro-library/Questionnaire/promis-depression-sf4a|0.1.3"

* relatedArtifact[+].type = #citation
* relatedArtifact[=].display = "Pilkonis PA, Choi SW, Reise SP, Stover AM, Riley WT, Cella D. Item banks for measuring emotional distress from the Patient-Reported Outcomes Measurement Information System (PROMIS): depression, anxiety, and anger. Assessment 2011;18(3):263-83."
* relatedArtifact[=].url = "https://doi.org/10.1177/1073191111411667"

* copyright = """FHIR encoding © 2026 BIH-CEI. CC-BY-4.0.
PROMIS Depression SF-4a © PROMIS Health Organization, freely available with attribution."""

* extension[+].url = $cqf-knowledgeCapability
* extension[=].valueCode = #shareable
* extension[+].url = $cqf-knowledgeCapability
* extension[=].valueCode = #computable
* extension[+].url = $cqf-knowledgeCapability
* extension[=].valueCode = #executable
* extension[+].url = $cqf-knowledgeRepresentationLevel
* extension[=].valueCode = #executable

* content[+].contentType = #text/cql
* content[=].title = "PROMISDepressionSF4a.cql"
* content[=].data = ""

* content[+].contentType = #application/elm+json
* content[=].title = "PROMISDepressionSF4a.json"
* content[=].data = ""
